      <category term="白日梦" scheme="http://echo.engineer/tags/%E7%99%BD%E6%97%A5%E6%A2%A6/"/>
    
      <category term="钢琴曲" scheme="http://echo.engineer/tags/%E9%92%A2%E7%90%B4%E6%9B%B2/"/>
    
      <category term="田园诗人" scheme="http://echo.engineer/tags/%E7%94%B0%E5%9B%AD%E8%AF%97%E4%BA%BA/"/>
    
